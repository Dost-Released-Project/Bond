<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1; background-color: rgb(82, 49, 49);">
        <ui:Button text="Reinforce" name="btn-reinforce" style="position: absolute; width: 200px; height: 200px; top: 40%; left: 20%; font-size: 40px;"/>
        <ui:Button text="Normal" name="btn-normal" style="position: absolute; width: 200px; height: 200px; font-size: 55px; top: 40%; left: 45%;"/>
        <ui:Button text="Special" name="btn-special" style="position: absolute; left: 70%; top: 40%; width: 200px; height: 200px; font-size: 55px;"/>
        <ui:Button text="X" name="btn-close-supply" style="position: absolute; top: auto; left: auto; align-self: flex-end; width: 200px; height: 200px; font-size: 200px;"/>
    </ui:VisualElement>
</ui:UXML>
