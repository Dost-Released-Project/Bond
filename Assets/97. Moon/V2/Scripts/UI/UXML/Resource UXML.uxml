            </ui:VisualElement>
            <ui:VisualElement name="resource-group" class="resource-group" style="flex-grow: 1; position: absolute; right: 34%;">
                <ui:Label text="Label" name="label-wood" class="resource-label" style="-unity-text-align: middle-right;"/>
                <ui:VisualElement name="VisualElement" class="resource-icon" style="background-image: url(&quot;project://database/Assets/97.%20Moon/V2/Image/tree-small.png?fileID=2800000&amp;guid=8ebc6fb546c63964292316f80719c458&amp;type=3#tree-small&quot;); -unity-background-image-tint-color: rgb(200, 100, 0);"/>
            </ui:VisualElement>
            <ui:VisualElement name="resource-group" class="resource-group" style="flex-grow: 1; align-items: stretch; position: absolute; right: 1%;">
