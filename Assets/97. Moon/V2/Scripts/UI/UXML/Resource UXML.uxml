    <ui:VisualElement picking-mode="Ignore" style="flex-grow: 1; position: absolute; width: 100%; height: 60px; background-color: rgba(14, 16, 22, 0.7);">
        <ui:VisualElement name="resource-container" style="flex-grow: 1; width: 1795px; background-color: rgba(14, 16, 22, 0);">
