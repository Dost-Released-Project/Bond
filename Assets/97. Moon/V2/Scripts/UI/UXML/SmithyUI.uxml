                <ui:Label text="0&#10;0&#10;0" name="stat-info" style="position: absolute; -unity-text-align: middle-left; top: 50px; left: auto; font-size: 50px; width: 105px; height: 150px; right: 100px;"/>
            </ui:VisualElement>
        </ui:VisualElement>
