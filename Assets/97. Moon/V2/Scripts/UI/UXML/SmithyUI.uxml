    <ui:VisualElement name="VisualElement" style="flex-grow: 1; position: absolute; width: 960px; height: 540px; top: 262px; left: 482px;">
        <ui:Button text="" name="btn-close" style="background-image: url(&quot;project://database/Assets/97.%20Moon/V2/Image/close-x.png?fileID=2800000&amp;guid=fca488c12ed21e747bd5ba7a7485df0f&amp;type=3#close-x&quot;); width: 50px; height: 50px;"/>
        <ui:VisualElement name="smithy-main-body" class="smithy-main-body">
            <ui:VisualElement name="smithy-left-panel" class="smithy-left-panel" style="flex-grow: 1;">
                <ui:VisualElement name="smithy-slot-row" class="smithy-slot-row">
                    <ui:Button text="" name="slot-weapon" style="background-image: url(&quot;project://database/Assets/97.%20Moon/V2/Image/sword.png?fileID=2800000&amp;guid=442c345d0aa33ee47ae2581689acc6b1&amp;type=3#sword&quot;);"/>
