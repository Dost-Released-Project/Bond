            <ui:Label text="(+0)" name="item-name" style="font-size: 40px; left: 0; right: 0; -unity-text-align: middle-center; white-space: nowrap; text-overflow: clip; -unity-text-auto-size: none; -unity-text-generator: standard; position: absolute; top: 0; height: 80px; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; margin-bottom: 2px;"/>
