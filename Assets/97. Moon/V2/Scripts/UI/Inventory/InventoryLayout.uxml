        <ui:Button text="Consume" name="btn-filter-consumable" style="width: 100px; height: 100px; -unity-text-align: middle-center; white-space: pre; top: 240px; right: 35px; left: auto; bottom: auto; font-size: 20px; position: absolute;"/>
