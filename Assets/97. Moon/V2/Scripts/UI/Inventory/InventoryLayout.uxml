        <ui:ScrollView name="total-inventory-grid" horizontal-scroller-visibility="Hidden" vertical-scroller-visibility="Hidden" mode="Vertical" style="position: absolute; top: 100px; width: 450px; height: 600px; flex-direction: row; white-space: normal; flex-wrap: wrap; align-items: stretch; align-self: auto; align-content: flex-start; flex-shrink: 1; flex-grow: 1; left: 40px;">
