<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/97.%20Moon/V2/Scripts/UI/Inventory/InventoryStyle.uss?fileID=7433441132597879392&amp;guid=2d9b46e0e3f6b80438edfeb73b2d389a&amp;type=3#InventoryStyle"/>
    <ui:VisualElement name="inventory-container" style="flex-grow: 1; flex-wrap: nowrap; width: 700px; height: 1080px; aspect-ratio: auto; background-image: none; flex-direction: column; background-color: rgb(136, 121, 96); position: absolute;">
        <ui:ScrollView name="total-inventory-grid" horizontal-scroller-visibility="Hidden" vertical-scroller-visibility="Hidden" mode="Vertical" style="position: absolute; top: 100px; width: 450px; height: 450px; flex-direction: row; white-space: normal; flex-wrap: wrap; align-items: stretch; align-self: auto; align-content: flex-start; flex-shrink: 1; flex-grow: 1;">
            <ui:VisualElement name="total-grid" style="flex-grow: 1; flex-direction: row; flex-wrap: wrap; align-items: flex-start; width: 450px; height: 450px;"/>
        </ui:ScrollView>
        <ui:VisualElement name="expedition-inventory-grid" style="flex-grow: 1; flex-wrap: wrap; top: 55%; left: auto; position: absolute; height: 200px; width: 630px; flex-direction: row; background-position-y: center; flex-shrink: 1; align-items: flex-start;"/>
        <ui:Button text="Sort" name="btn-sort" style="width: 100px; height: 100px; -unity-text-align: middle-center; white-space: pre; top: 100px; right: 0; left: 500px; bottom: 0; font-size: 40px; position: absolute;"/>
        <ui:Button text="Consume" name="btn-filter-consumable" style="width: 100px; height: 100px; -unity-text-align: middle-center; white-space: pre; top: 200px; right: 0; left: 500px; bottom: 0; font-size: 20px; position: absolute;"/>
        <ui:Button text="Equip" name="btn-filter-accessory" style="width: 100px; height: 100px; -unity-text-align: middle-center; white-space: pre; top: 300px; right: 0; left: 500px; bottom: 0; font-size: 37px; position: absolute;"/>
        <ui:Button text="All" name="btn-filter-all" style="width: 100px; height: 100px; -unity-text-align: middle-center; white-space: pre; top: 400px; right: 0; left: 500px; bottom: 0; font-size: 40px; position: absolute;"/>
        <ui:Button text="X" name="btn-close" style="width: 100px; height: 100px; -unity-text-align: middle-center; white-space: pre; top: 800px; right: 10%; left: auto; bottom: auto; font-size: 100px; position: absolute;"/>
        <ui:TextField label="Search" placeholder-text="filler text" name="inventory-search" style="width: 400px; height: 50px; align-items: center; justify-content: space-around; font-size: 30px; top: 825px; position: absolute; bottom: auto; background-color: rgb(128, 255, 0);"/>
    </ui:VisualElement>
</ui:UXML>
