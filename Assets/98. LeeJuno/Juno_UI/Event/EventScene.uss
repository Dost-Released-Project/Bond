.event-root {
    flex: 1;
    align-items: center;
    justify-content: center;
}

.event-choice-container {
    flex-direction: column;
    align-items: stretch;
    width: 400px;
}

.event-choice-button {
    margin: 4px;
    padding: 8px;
    font-size: 16px;
}

.event-choice-label {
    white-space: normal;
    -unity-text-align: middle-center;
}
