<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:Template name="EquipSlots" src="project://database/Assets/UI/Shared/EquipSlots.uxml?fileID=9197481963319205126&amp;guid=0afe954fcb08c654b84cafa7c98f94d5&amp;type=3#EquipSlots"/>
    <Style src="project://database/Assets/UI/Themes/EoB_Theme_DarkAmber.uss?fileID=7433441132597879392&amp;guid=fa8c2ca04fc0ab24991530664bb55c09&amp;type=3#EoB_Theme_DarkAmber"/>
    <Style src="project://database/Assets/UI/Town/CharacterDetail.uss?fileID=7433441132597879392&amp;guid=5fa1beccce78a3340a99d2b36c82c87f&amp;type=3#CharacterDetail"/>
    <Style src="project://database/Assets/UI/Shared/EquipSlots.uss?fileID=7433441132597879392&amp;guid=33c57ec0ad856974abe818e36e15d6f0&amp;type=3#EquipSlots"/>
    <ui:VisualElement name="character-detail" class="character-detail character-detail--hidden">
        <ui:VisualElement class="character-detail__header">
            <ui:Label name="character-detail__title" text="" class="character-detail__title"/>
            <ui:Button name="character-detail__close-btn" text="✕" class="character-detail__close-btn"/>
        </ui:VisualElement>
        <ui:VisualElement name="character-detail__body" class="character-detail__body">
            <ui:VisualElement class="char-detail__layout">
                <ui:VisualElement class="char-detail__left-col">
                    <ui:Image name="char-detail__portrait" class="char-detail__portrait"/>
                    <ui:VisualElement class="char-detail__identity">
                        <ui:Label name="char-detail__class-level" text="" class="char-detail__class-level"/>
                        <ui:VisualElement name="control-mode" class="char-detail__control-seg">
                            <ui:Button name="control-seg-manual" text="수동" class="char-detail__control-seg__opt char-detail__control-seg__opt--manual char-detail__control-seg__opt--active"/>
                            <ui:Button name="control-seg-auto" text="자동" class="char-detail__control-seg__opt char-detail__control-seg__opt--auto"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="char-detail__base-stats">
                        <ui:VisualElement class="char-detail__base-stat-boxes">
                            <ui:VisualElement class="char-detail__base-stat-box">
                                <ui:Label text="STR" class="char-detail__base-stat-key"/>
                                <ui:Label name="base-stat-str" text="0" class="char-detail__base-stat-val"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="char-detail__base-stat-box">
                                <ui:Label text="AGI" class="char-detail__base-stat-key"/>
                                <ui:Label name="base-stat-agi" text="0" class="char-detail__base-stat-val"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="char-detail__base-stat-box">
                                <ui:Label text="INT" class="char-detail__base-stat-key"/>
                                <ui:Label name="base-stat-int" text="0" class="char-detail__base-stat-val"/>
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="char-detail__combat-stats">
                        <ui:VisualElement class="char-detail__stat-row">
                            <ui:Label text="HP" class="char-detail__stat-key"/>
                            <ui:Label name="stat-hp" text="0" class="char-detail__stat-val"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="char-detail__gauge">
                            <ui:VisualElement class="char-detail__gauge-track">
                                <ui:VisualElement name="gauge-hp" class="char-detail__gauge-fill char-detail__gauge-fill--hp"/>
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="char-detail__gauge-block">
                            <ui:VisualElement class="char-detail__gauge-label-row">
                                <ui:Label text="광기" class="char-detail__gauge-label char-detail__gauge-label--insanity"/>
                                <ui:Label name="gauge-insanity-warn" text="" class="char-detail__gauge-warn"/>
                                <ui:Label name="gauge-insanity-val" text="0 / 100" class="char-detail__gauge-val"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="char-detail__gauge">
                                <ui:VisualElement class="char-detail__gauge-track">
                                    <ui:VisualElement name="gauge-insanity" class="char-detail__gauge-fill"/>
                                </ui:VisualElement>
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement class="char-detail__stat-row">
                            <ui:Label text="DEF" class="char-detail__stat-key"/>
                            <ui:Label name="stat-def" text="0" class="char-detail__stat-val"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="char-detail__stat-row">
                            <ui:Label text="ATK" class="char-detail__stat-key"/>
                            <ui:Label name="stat-atk" text="0" class="char-detail__stat-val"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="char-detail__stat-row">
                            <ui:Label text="SPD" class="char-detail__stat-key"/>
                            <ui:Label name="stat-spd" text="0" class="char-detail__stat-val"/>
                        </ui:VisualElement>
