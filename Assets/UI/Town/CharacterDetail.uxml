                            <ui:Label text="치명타" class="char-detail__stat-key"/>
                            <ui:Label name="stat-crt" text="0%" class="char-detail__stat-val"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="char-detail__stat-row">
                            <ui:Label text="명중" class="char-detail__stat-key"/>
                            <ui:Label name="stat-acc" text="0%" class="char-detail__stat-val"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="char-detail__stat-row">
